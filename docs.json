{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "WhatsApp Use",
  "description": "Developer documentation for the WhatsApp Use API and remote MCP server.",
  "colors": {
    "primary": "#0B944B",
    "light": "#08733C",
    "dark": "#0E1611"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://whatsapp-use.com"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": {
      "light": "#EEF7F1",
      "dark": "#0D1510"
    }
  },
  "api": {
    "openapi": "openapi/whatsapp-use.yaml",
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["curl", "javascript", "python", "go"],
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "guides/concepts",
              "guides/pair-whatsapp",
              "guides/send-message",
              "guides/webhooks",
              "guides/ai-readable-docs"
            ]
          }
        ]
      },
      {
        "tab": "REST API",
        "icon": "braces",
        "groups": [
          {
            "group": "API basics",
            "pages": [
              "api/authentication",
              "api/connections",
              "api/scopes"
            ]
          },
          {
            "group": "Account",
            "openapi": "openapi/whatsapp-use.yaml",
            "expanded": false,
            "pages": [
              "GET /v1/me",
              "GET /v1/usage"
            ]
          },
          {
            "group": "Connections and sync",
            "openapi": "openapi/whatsapp-use.yaml",
            "expanded": false,
            "pages": [
              "GET /v1/whatsapp/status",
              "POST /v1/whatsapp/pair",
              "GET /v1/whatsapp/pair/status",
              "GET /v1/whatsapp/sync",
              "GET /v1/whatsapp/conversations",
              "GET /v1/whatsapp/contacts",
              "GET /v1/whatsapp/conversations/{conversation_id}/messages",
              "GET /v1/whatsapp/media/{message_id}",
              "POST /v1/whatsapp/unlink"
            ]
          },
          {
            "group": "Messages",
            "openapi": "openapi/whatsapp-use.yaml",
            "expanded": false,
            "pages": [
              "POST /v1/whatsapp/messages/send",
              "POST /v1/whatsapp/messages/react",
              "POST /v1/whatsapp/messages/edit",
              "POST /v1/whatsapp/messages/delete",
              "POST /v1/whatsapp/messages/read",
              "POST /v1/whatsapp/conversations/{conversation_id}/read"
            ]
          },
          {
            "group": "Groups",
            "openapi": "openapi/whatsapp-use.yaml",
            "expanded": false,
            "pages": [
              "POST /v1/whatsapp/groups",
              "POST /v1/whatsapp/groups/{group_jid}/participants"
            ]
          },
          {
            "group": "Webhooks",
            "openapi": "openapi/whatsapp-use.yaml",
            "expanded": false,
            "pages": [
              "GET /v1/webhooks/endpoints",
              "POST /v1/webhooks/endpoints",
              "PATCH /v1/webhooks/endpoints/{endpoint_id}",
              "POST /v1/webhooks/endpoints/{endpoint_id}/rotate-secret",
              "DELETE /v1/webhooks/endpoints/{endpoint_id}",
              "POST /v1/webhooks/endpoints/{endpoint_id}/test",
              "GET /v1/webhooks/deliveries"
            ]
          }
        ]
      },
      {
        "tab": "MCP",
        "icon": "bot",
        "groups": [
          {
            "group": "Remote MCP",
            "pages": [
              "mcp/overview",
              "mcp/install",
              "mcp/oauth",
              "mcp/tools"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Platform",
          "href": "https://platform.whatsapp-use.com",
          "icon": "layout-dashboard"
        },
        {
          "anchor": "Website",
          "href": "https://whatsapp-use.com",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Platform",
        "href": "https://platform.whatsapp-use.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://platform.whatsapp-use.com/app/keys"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "add-mcp",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pally-ai"
    }
  }
}
