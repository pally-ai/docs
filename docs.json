{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "WhatsApp Use",
  "description": "Developer documentation for the WhatsApp Use API and remote MCP server.",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://whatsapp-use.com"
  },
  "api": {
    "openapi": "openapi/whatsapp-use.yaml",
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": ["curl", "javascript", "python", "go"],
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "guides/concepts",
              "guides/pair-whatsapp",
              "guides/send-message",
              "guides/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "REST API",
        "icon": "braces",
        "groups": [
          {
            "group": "API basics",
            "pages": [
              "api/authentication",
              "api/connections",
              "api/scopes"
            ]
          },
          {
            "group": "Reference",
            "openapi": "openapi/whatsapp-use.yaml"
          }
        ]
      },
      {
        "tab": "MCP",
        "icon": "bot",
        "groups": [
          {
            "group": "Remote MCP",
            "pages": [
              "mcp/overview",
              "mcp/install",
              "mcp/oauth",
              "mcp/tools"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Platform",
          "href": "https://platform.whatsapp-use.com",
          "icon": "layout-dashboard"
        },
        {
          "anchor": "Website",
          "href": "https://whatsapp-use.com",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Platform",
        "href": "https://platform.whatsapp-use.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://platform.whatsapp-use.com/app/keys"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "add-mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pally-ai"
    }
  }
}
